Bootstrap: docker
From: ubuntu:22.04

%environment
LANG=en_US.UTF-8
LANGUAGE=en_US:en
LC_ALL=en_US.UTF-8

%post
# Ensure noninteractive install
export DEBIAN_FRONTEND=noninteractive

# Update and install prerequisites
apt-get update && apt-get upgrade -y
apt-get install -y wget unzip libgomp1 locales
locale-gen en_US.UTF-8
update-locale LANG=en_US.UTF-8

# Install Microsoft package repository for Ubuntu 22.04
wget https://packages.microsoft.com/config/ubuntu/22.04/packages-microsoft-prod.deb -O packages-microsoft-prod.deb
dpkg -i packages-microsoft-prod.deb
rm packages-microsoft-prod.deb

# Update repositories and install .NET SDK (8.0.407 or newer)
apt-get update && apt-get install -y dotnet-sdk-8.0

# Clean up
apt-get clean && rm -rf /var/lib/apt/lists/*

# Install DIA-NN
wget https://github.com/vdemichev/DiaNN/releases/download/2.0/DIA-NN-2.2.0-Academia-Linux.zip -O diann-2.2.0.zip
unzip diann-2.2.0.zip
chmod -R 775 /diann-2.2.0

%environment
export DOTNET_ROOT=/usr/share/dotnet
export PATH=$PATH:/usr/share/dotnet

%runscript
diann --about
dotnet --info